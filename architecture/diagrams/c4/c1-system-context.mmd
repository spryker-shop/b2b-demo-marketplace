flowchart LR
    HQ["👤 Headquarter User<br>(Daimler Germany)"] -- Manage all markets, monitoring --> Spryker["🛒 Daimler Truck<br>B2B Parts Marketplace<br>(Spryker)"]
    Market["👤 Market User<br>(22 subsidiaries)"] -- Manage own market & dealers --> Spryker
    Dealer["👤 Dealer User<br>(Merchant)"] -- Prices, customer pool, orders --> Spryker
    Customer["👤 Customer<br>(workshop org)"] -- Browse & order parts --> Spryker

    IParts["📦 IParts<br>Catalog + part-vehicle match<br>(REST)"] -- Catalog structure, PLP/search --> Spryker
    VIS["🚚 VIS<br>Vehicle info, FIN/VIN<br>(REST)"] -- Vehicle data card --> Spryker
    TruckLog["📊 TruckLog DIMS<br>Availability (SOAP)"] -- Stock/availability --> Spryker
    LogBus["📊 MB LogBus DIMS<br>Availability (REST)"] -- Stock/availability (fallback) --> Spryker
    CRISP["💾 CRISP<br>Customer org (REST)"] -- Customer org info --> Spryker
    IPS["💾 IPS<br>Prices & parts master<br>(XML/SFTP → S3)"] -- Full XML import --> Spryker
    RetailNet["💾 RetailNet<br>Dealer org (REST)"] -- Dealer org info --> Spryker
    Spryker <-- Locate/register dealer --> Locator["🔗 Dealer Locator<br>(Linkout)"]
    Spryker <-- External catalog, basket --> FUSO["🔗 FUSO / BPC<br>External catalogs<br>(Linkout/REST)"]
    Customer -- Authentication --> IAM["🔐 DTAG IAM<br>Empower ID (OAuth)"]
    IAM -- Tokens, identity --> Spryker

    HQ:::userStyle
    Market:::userStyle
    Dealer:::userStyle
    Customer:::userStyle
    Spryker:::systemStyle
    IParts:::externalStyle
    VIS:::externalStyle
    TruckLog:::externalStyle
    LogBus:::externalStyle
    CRISP:::externalStyle
    IPS:::externalStyle
    RetailNet:::externalStyle
    Locator:::externalStyle
    FUSO:::externalStyle
    IAM:::externalStyle
