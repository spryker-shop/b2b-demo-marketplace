%% C1 System Context — Scania Service Sales POC
%% Provenance: HARVESTED from the Scania TAD (Confluence page 5670961154, "Target Architecture Diagram C1",
%% embedded Mermaid by Dimitriy Kravchenko). Restyled to the architecture-prep colour convention
%% (userStyle / systemStyle / externalStyle) and relabelled for consistency with sections 03/06/11.
---
config:
  layout: elk
---
flowchart LR
    Customer(["👤 Fleet Customer<br><small>Browses vehicles, selects<br>and purchases services online</small>"])
    Spryker["🛒 Scania Service Shop<br>(Spryker B2B Marketplace)<br><small>Log in, browse fleet, find<br>services, place orders</small>"]
    CIAM["🔐 CIAM — My Scania<br><small>Verifies identity, returns<br>profile, company, roles</small>"]
    FMAT["🚛 FMAT — Fleet Management<br><small>Owns the customer's vehicles;<br>receives post-order notifications</small>"]
    SECM["📋 SECM — Service Catalog<br><small>Available services and<br>prices per vehicle</small>"]
    SPISA["📦 PIM-SPISA — Service Details<br><small>Descriptions, images and<br>(potential) configuration</small>"]
    EMAIL["📧 SMTP / Email<br><small>Sends order confirmations</small>"]

    Customer -- "Logs in &amp; browses shop<br>[HTTPS]" --> Spryker
    Spryker -- "Authenticates customer<br>[OAuth2/OIDC, sync]" --> CIAM
    CIAM -- "Profile, company, roles<br>[REST, sync]" --> Spryker
    Spryker -- "Retrieves customer's vehicles<br>[REST, sync]" --> FMAT
    Spryker -- "Retrieves services &amp; prices<br>[REST, sync]" --> SECM
    Spryker -- "Retrieves service details<br>[REST, sync]" --> SPISA
    Spryker -- "Notifies of new orders (x2)<br>[REST, async via OMS]" --> FMAT
    Spryker -- "Sends order confirmation<br>[SMTP]" --> EMAIL
    EMAIL -- "Receives confirmation" --> Customer

    Customer:::userStyle
    Spryker:::systemStyle
    CIAM:::externalStyle
    FMAT:::externalStyle
    SECM:::externalStyle
    SPISA:::externalStyle
    EMAIL:::externalStyle
    classDef userStyle fill:#e1f5ff,stroke:#0366d6,stroke-width:2px
    classDef systemStyle fill:#E67E22,stroke:#c0392b,stroke-width:3px,color:#fff
    classDef externalStyle fill:#95A5A6,stroke:#7f8c8d,stroke-width:2px,color:#fff
