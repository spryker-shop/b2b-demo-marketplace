%% C2 Container — Daimler Truck B2B Parts (After Sales)
%% Single shared DB/Redis/ES region (DMS, 22 stores). Product search/filter delegated to an
%% external Daimler catalog API (Spryker OpenSearch NOT used for product search/filtering).
%% No PSP (Invoice only). Full XML import lands on S3.
---
config:
   layout: elk
---
flowchart LR
   subgraph Spryker["Spryker B2B Marketplace Platform (single region, DMS 22 stores)"]
      Yves["🌐 Yves<br><small>Twig + PHP</small><br><small>Storefront (headless later)</small>"]
      BackOffice["🏢 BackOffice<br><small>Twig + PHP</small><br><small>HQ + per-market admin (Persistence ACL)</small>"]
      MerchantPortal["🏪 Merchant Portal<br><small>Twig + PHP</small><br><small>Dealer customer &amp; order mgmt</small>"]
      StoreFrontAPI["🔌 Storefront API<br><small>PHP / Glue</small><br><small>Headless-ready</small>"]
      BackendGateway["🚪 Backend Gateway<br><small>PHP</small><br><small>Yves↔Zed RPC</small>"]
      MySQL["🗄️ MariaDB<br><small>Single shared relational DB (all products global)</small>"]
      Redis["⚡ Redis<br><small>Single shared KV (sessions, storage)</small>"]
      OpenSearch["🔍 OpenSearch<br><small>NOT used for product search/filter — CMS/utility only</small>"]
      RabbitMQ["📬 RabbitMQ<br><small>Per-region vhost, Publish &amp; Sync</small>"]
      Jenkins["⏰ Scheduler<br><small>Jenkins + PHP</small><br><small>Import, P&amp;S workers, OMS cron</small>"]
      FileStorage["📁 AWS S3<br><small>IPS XML import bucket</small>"]
   end

   Customer["👤 Customer"] -- Browse &amp; order [HTTPS] --> Yves
   DealerUser["👤 Dealer User"] -- Manage [HTTPS] --> MerchantPortal
   MarketHQUser["👤 Market / HQ BO User"] -- Administer [HTTPS] --> BackOffice

   Yves -- RPC [HTTPS] --> BackendGateway
   Yves -- Sessions / storage [TCP] --> Redis
   StoreFrontAPI -- RPC [HTTPS] --> BackendGateway
   BackendGateway -- Read/Write [SQL] --> MySQL
   BackOffice -- Read/Write [SQL] --> MySQL
   MerchantPortal -- Read/Write [SQL] --> MySQL
   MySQL -- Trigger events [AMQP] --> RabbitMQ
   RabbitMQ -- Publish &amp; Sync [AMQP] --> Jenkins
   Jenkins -- Read import files [S3 API] --> FileStorage
   Jenkins -- CTE bulk write [SQL] --> MySQL
   Jenkins -- Populate KV [TCP] --> Redis
   Jenkins -- Index CMS/utility [REST] --> OpenSearch

   %% External integrations
   Customer -- Auth [OAuth] --> IAM["🔐 DTAG IAM<br><small>External</small>"]
   IAM -- Tokens/claims [REST] --> Yves & BackOffice
   IPS["🗄️ IPS<br><small>External</small>"] -- Prices + master [SFTP/XML] --> FileStorage
   IParts["📦 IParts<br><small>External</small>"] -- Catalog + fitment [REST] --> BackendGateway
   VIS["🚚 VIS<br><small>External</small>"] -- FIN/VIN [REST] --> BackendGateway
   TruckLog["📡 TruckLog / MB LogBus DIMS<br><small>External</small>"] -- Availability [SOAP/REST] --> BackendGateway
   CRISP["🏢 CRISP<br><small>External</small>"] -- Customer org [REST] --> BackendGateway
   RetailNet["🏢 RetailNet<br><small>External</small>"] -- Dealer org [REST] --> BackendGateway
   Yves -- Product search / filter [REST] --> ExtSearch["🔍 External Catalog Search API<br><small>External (delegated PLP)</small>"]
   Yves -- Linkout + basket [Linkout/REST] --> FUSO["🔗 FUSO / BPC<br><small>External</small>"]
   Yves -- Linkout [Linkout] --> Locator["🔗 Dealer Locator<br><small>External</small>"]

   Yves:::webAppStyle
   BackOffice:::webAppStyle
   MerchantPortal:::webAppStyle
   StoreFrontAPI:::apiStyle
   BackendGateway:::infraStyle
   MySQL:::storageStyle
   Redis:::storageStyle
   OpenSearch:::storageStyle
   RabbitMQ:::infraStyle
   Jenkins:::infraStyle
   FileStorage:::storageStyle
   Customer:::userStyle
   DealerUser:::userStyle
   MarketHQUser:::userStyle
   IAM:::externalStyle
   IPS:::externalStyle
   IParts:::externalStyle
   VIS:::externalStyle
   TruckLog:::externalStyle
   CRISP:::externalStyle
   RetailNet:::externalStyle
   ExtSearch:::apiStyle
   FUSO:::externalStyle
   Locator:::externalStyle
   classDef userStyle fill:#e1f5ff,stroke:#0366d6,stroke-width:2px
   classDef webAppStyle fill:#27AE60,stroke:#27ae60,stroke-width:2px,color:#fff
   classDef apiStyle fill:#2980B9,stroke:#2980b9,stroke-width:2px,color:#fff
   classDef storageStyle fill:#9B59B6,stroke:#8e44ad,stroke-width:2px,color:#fff
   classDef infraStyle fill:#95A5A6,stroke:#95a5a6,stroke-width:2px,color:#fff
   classDef externalStyle fill:#95A5A6,stroke:#7f8c8d,stroke-width:2px,color:#fff
