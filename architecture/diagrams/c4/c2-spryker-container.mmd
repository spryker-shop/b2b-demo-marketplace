---
config:
   layout: elk
---
flowchart LR
   subgraph Spryker["Scania Service Shop — Spryker B2B Marketplace (POC)"]
      Yves["🌐 Yves<br><small>Twig + PHP</small><br><small>Storefront: asset selection, service browsing,<br>service detail, cart, checkout, order history</small>"]
      BackOffice["🏢 BackOffice<br><small>Twig + PHP</small><br><small>Order mgmt, company/role admin, OMS view</small>"]
      BackendGateway["🚪 Backend Gateway (Zed)<br><small>PHP</small><br><small>Business logic, OMS, integration clients</small>"]
      MySQL["🗄️ MariaDB<br><small>Orders, customers, companies, cart</small>"]
      Redis["⚡ Redis<br><small>Sessions & KV storage (per store)</small>"]
      OpenSearch["🔍 OpenSearch<br><small>Catalog search (minimal for POC)</small>"]
      RabbitMQ["📬 RabbitMQ<br><small>OMS async commands (FMAT post-order, email)</small>"]
      Scheduler["⏰ Scheduler<br><small>Jenkins + PHP</small><br><small>oms:check-timeout / check-condition, P&S</small>"]
      subgraph Custom["Project (Pyz) custom modules"]
         CiamAuth["🔐 CiamSso<br><small>OAuth strategy plugin, JIT customer + role map</small>"]
         AssetClient["🚚 FmatAsset<br><small>Client — live asset fetch, paginated</small>"]
         ServiceCat["🧰 SecmServiceCatalog<br><small>Client — services + prices per vehicle</small>"]
         ServiceDetail["📦 SpisaServiceDetail<br><small>Client — service details / configurator</small>"]
         DynService["🛒 DynamicServiceCart<br><small>Dynamic service item + price modelling (SD-001)</small>"]
         FmatNotify["📨 FmatOrderNotification<br><small>OMS commands — post-order calls</small>"]
      end
   end
   FleetCustomer["👤 Fleet Customer"] -- Browse & purchase<br>[HTTPS] --> Yves
   BackofficeUser["👤 Back Office User"] -- Manage platform<br>[HTTPS] --> BackOffice
   Yves -- Business requests<br>[HTTPS] --> BackendGateway
   Yves -- Sessions / KV<br>[TCP] --> Redis
   Yves -- Search / catalog<br>[REST] --> OpenSearch
   BackOffice -- Read/Write<br>[SQL] --> MySQL
   BackendGateway -- Read/Write<br>[SQL] --> MySQL
   Scheduler -- Trigger events / P&S<br>[AMQP] --> RabbitMQ
   Scheduler -- Read/Write<br>[SQL] --> MySQL
   Scheduler -- Populate KV<br>[TCP] --> Redis

   CiamAuth -- SSO login, fetch profile/roles<br>[REST — protocol TBD] --> CIAM["🔐 CIAM (My Scania)<br><small>External</small>"]
   AssetClient -- Fetch vehicles (live)<br>[REST — protocol TBD] --> FMAT["🚚 FMAT<br><small>External</small>"]
   ServiceCat -- Fetch services + prices<br>[REST — protocol TBD] --> SECM["🧰 SECM<br><small>External</small>"]
   ServiceDetail -- Fetch service details<br>[REST — protocol TBD] --> PIMSPISA["📦 PIM-SPISA<br><small>External</small>"]
   FmatNotify -- Post-order notify (async)<br>[REST — protocol TBD] --> FMAT
   Scheduler -- Order confirmation<br>[SMTP] --> SMTP["✉️ SMTP<br><small>External</small>"]

