flowchart LR
   subgraph Spryker["NORMA Spryker Platform (Phase 1: 1 region / 1 store / DE)"]
      Yves["🌐 Yves<br><small>Twig + PHP</small><br><small>Storefront + custom return portal + JS widgets</small>"]
      BackOffice["🏢 Back Office<br><small>Twig + PHP</small><br><small>Admin / OMS / import UI</small>"]
      StoreFrontAPI["🔌 Storefront API<br><small>PHP / REST</small>"]
      BackendAPI["⚙️ Glue Backend API<br><small>PHP / REST</small><br><small>Talend import & order export; Data Exchange</small>"]
      MySQL["🗄️ MariaDB<br><small>Single DB</small>"]
      Redis["⚡ Redis<br><small>Sessions + KV storage</small>"]
      OpenSearch["🔍 Elasticsearch<br><small>Category / catalog index</small>"]
      RabbitMQ["📬 RabbitMQ<br><small>P&S + OMS + ACP events</small>"]
      Jenkins["⏰ Scheduler<br><small>Jenkins + PHP</small><br><small>Delta import 10min · order export 10min · OMS timeouts</small>"]
      FileStorage["📁 File Storage<br><small>AWS S3</small>"]
   end

   Customer["👤 Customer"] -- "Browse & Purchase<br>[HTTPS]" --> Yves
   BackofficeUser["👤 Back Office User"] -- "Manage<br>[HTTPS]" --> BackOffice
   Yves -- "Session / cache<br>[TCP]" --> Redis
   Yves -- "Category search<br>[REST]" --> OpenSearch
   Yves -- "Full-text search<br>[REST/JS]" --> SiteSearch["🔍 SiteSearch360<br><small>External</small>"]
   BackOffice -- "[SQL]" --> MySQL
   StoreFrontAPI -- "[REST]" --> Redis
   BackendAPI -- "[SQL]" --> MySQL
   MySQL -- "Trigger events<br>[AMQP]" --> RabbitMQ
   RabbitMQ -- "Publish & Sync<br>[AMQP]" --> Jenkins
   Jenkins -- "Populate KV<br>[TCP]" --> Redis
   Jenkins -- "Index catalog<br>[REST]" --> OpenSearch
   Jenkins -- "[SQL]" --> MySQL
   Jenkins -- "Import/export files<br>[S3 API]" --> FileStorage

   Talend["🔀 Talend ETL<br><small>External</small>"] -- "Delta catalog import<br>[REST]" --> BackendAPI
   BackendAPI -- "Order + payment export<br>[REST]" --> Talend
   Talend -- "[REST]" --> ERP["💾 Plentymarkets ERP<br><small>External</small>"]
   Yves -- "Payment iframe/redirect<br>[HTTPS]" --> Payone["💳 Payone ACP App<br><small>External</small>"]
   Payone -- "Payment events<br>[ACP bus]" --> RabbitMQ
   Jenkins -- "Return labels<br>[REST]" --> Carriers["📦 DHL/DPD/GLS<br><small>External</small>"]
   Yves -- "Address verify<br>[REST]" --> Melissa["📍 Melissa<br><small>External</small>"]
   BackendAPI -- "Product feed<br>[REST]" --> FeedDynamix["📤 Feed Dynamix<br><small>External</small>"]
   Jenkins -- "Campaigns<br>[REST]" --> Emarsys["✉️ Emarsys<br><small>External</small>"]
   BackendAPI -- "BI data<br>[VPN / Data Exchange]" --> DWH["📈 DWH<br><small>External</small>"]

