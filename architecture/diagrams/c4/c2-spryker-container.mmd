%% C2 Container — Scania Service Sales POC (Spryker B2B Marketplace, Yves storefront)
%% Scope: POC. Scania sole merchant, Dynamic Multistore (GB/PL/DE), no Merchant Portal in use for POC.
---
config:
   layout: elk
---
flowchart LR
   subgraph Spryker["Scania Service Shop — Spryker B2B Marketplace Platform"]
      Yves["🌐 Yves<br><small>Twig + PHP</small><br><small>Storefront: SSO login, fleet, service PDP, cart, checkout</small>"]
      BackOffice["🏢 BackOffice<br><small>Twig + PHP</small><br><small>Admin: orders, OMS, stores, company roles</small>"]
      BackendGateway["🚪 Backend Gateway<br><small>PHP</small><br><small>Yves ↔ Zed RPC</small>"]
      IntegrationModules["🧩 Scania Integration Modules<br><small>PHP (Client + Zed)</small><br><small>CIAM / FMAT / SECM / PIM-SPISA connectors</small>"]
      MySQL["🗄️ MySQL/MariaDB<br><small>Orders, customers, companies, quotes, dynamic service line items</small>"]
      Redis["⚡ Redis/Valkey<br><small>Sessions &amp; KV storage (per store)</small>"]
      OpenSearch["🔍 OpenSearch<br><small>Search index (per store)</small>"]
      RabbitMQ["📬 RabbitMQ<br><small>Message broker (per region vhost)</small>"]
      Jenkins["⏰ Scheduler<br>Jenkins + PHP<br><small>OMS process cron, Publish &amp; Sync workers</small>"]
      SMTP["📤 Mailer<br><small>OOTB order-confirmation mail</small>"]
   end

   Customer["👤 Fleet Customer<br><small>Company user browsing &amp; buying services</small>"] -- "Browse &amp; Purchase<br>[HTTPS]" --> Yves
   BackofficeUser["👤 Scania Back Office User<br><small>Order &amp; platform management</small>"] -- "Manage Platform<br>[HTTPS]" --> BackOffice

   Yves -- "Process requests<br>[HTTPS]" --> BackendGateway
   Yves -- "Sessions &amp; cache<br>[TCP]" --> Redis
   Yves -- "Search, catalog<br>[REST]" --> OpenSearch
   BackendGateway -- "Read/Write<br>[SQL]" --> MySQL
   BackOffice -- "Read/Write<br>[SQL]" --> MySQL
   Jenkins -- "OMS cron, P&amp;S<br>[SQL]" --> MySQL
   Jenkins -- "Consume/Publish<br>[AMQP]" --> RabbitMQ
   MySQL -- "Trigger events<br>[AMQP]" --> RabbitMQ
   Jenkins -- "Populate KV cache<br>[TCP]" --> Redis
   Jenkins -- "Index data<br>[REST]" --> OpenSearch
   BackOffice -- "OMS transitions<br>[SQL/PHP]" --> Jenkins

   %% External integrations (all via Scania integration modules)
   Yves -- "SSO login (Federated Auth)<br>[OAuth2/OIDC]" --> CIAM["🔐 CIAM — My Scania<br><small>External · SSO IdP</small>"]
   CIAM -- "id_token + claims<br>[REST]" --> Yves
   IntegrationModules -- "Fetch assets<br>[REST sync]" --> FMAT["🚛 FMAT<br><small>External · Fleet mgmt</small>"]
   IntegrationModules -- "Fetch services + prices<br>[REST sync]" --> SECM["📋 SECM<br><small>External · Service catalog</small>"]
   IntegrationModules -- "Fetch service details<br>[REST sync]" --> SPISA["📦 PIM-SPISA<br><small>External · Service details / configurator?</small>"]
   Jenkins -- "Post-order notify x2<br>[REST async, OMS command]" --> FMAT
   IntegrationModules -- "Client ↔ Zed<br>[RPC]" --> BackendGateway
   Jenkins -- "OMS command invokes connector<br>[PHP]" --> IntegrationModules
   Yves -- "Send confirmation<br>[queue]" --> SMTP
   SMTP -- "Order confirmation<br>[SMTP]" --> Customer

   Yves:::webAppStyle
   BackOffice:::webAppStyle
   IntegrationModules:::apiStyle
   BackendGateway:::infraStyle
   MySQL:::storageStyle
   Redis:::storageStyle
   OpenSearch:::storageStyle
   RabbitMQ:::infraStyle
   Jenkins:::infraStyle
   SMTP:::infraStyle
   Customer:::userStyle
   BackofficeUser:::userStyle
   CIAM:::externalStyle
   FMAT:::externalStyle
   SECM:::externalStyle
   SPISA:::externalStyle
   classDef userStyle fill:#e1f5ff,stroke:#0366d6,stroke-width:2px
   classDef webAppStyle fill:#27AE60,stroke:#27ae60,stroke-width:2px,color:#fff
   classDef apiStyle fill:#2980B9,stroke:#2980b9,stroke-width:2px,color:#fff
   classDef storageStyle fill:#9B59B6,stroke:#8e44ad,stroke-width:2px,color:#fff
   classDef infraStyle fill:#95A5A6,stroke:#95a5a6,stroke-width:2px,color:#fff
   classDef externalStyle fill:#95A5A6,stroke:#7f8c8d,stroke-width:2px,color:#fff
