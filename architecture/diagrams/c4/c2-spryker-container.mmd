---
config:
  layout: elk
---
flowchart TB
    Customer["👤 Customer"] --> Yves
    Dealer["👤 Dealer (Merchant)"] --> MP
    HQMarket["👤 HQ / Market User"] --> Zed

    subgraph Spryker["Daimler Truck B2B Parts Marketplace — Spryker Cloud, 1 EU region, 22 DMS stores, one domain"]
        Yves["🛒 Yves<br><small>Storefront (single domain, store per request)</small>"]
        Zed["⚙️ Zed<br><small>Back Office (HQ + market-isolated)</small>"]
        MP["🏬 Merchant Portal<br><small>Dealer self-service</small>"]
        Glue["🔌 Glue Backend API<br><small>System-to-system</small>"]
        Import["📥 Import pipeline<br><small>Middleware split + CTE bulk import</small>"]
        DB["🗄️ Single DB<br><small>MariaDB/MySQL — products global/shared</small>"]
        Redis["⚡ Single Redis<br><small>P&S storage</small>"]
        ES["🔍 Elasticsearch/OpenSearch<br><small>NOT used for product search</small>"]
        MQ["📬 RabbitMQ<br><small>multi-queue P&S</small>"]
    end

    S3["📁 S3 bucket<br><small>IPS full XML files</small>"] --> Import
    Import -- CTE bulk write --> DB
    DB -- events [AMQP] --> MQ
    MQ -- Publish & Sync --> Redis
    Yves -- KV read --> Redis
    Yves -- read --> DB
    Zed -- read/write --> DB
    MP -- read/write --> DB
    Glue -- read/write --> DB

    Yves -- catalog/PLP [REST] --> IParts["📦 IParts"]
    Yves -- FIN/VIN [REST] --> VIS["🚚 VIS"]
    Yves -- availability [SOAP/REST] --> DIMS["📊 DIMS<br>TruckLog / MB LogBus"]
    Yves -- auth [OAuth] --> IAM["🔐 DTAG IAM"]
    Zed -- customer org [REST] --> CRISP["💾 CRISP"]
    Zed -- dealer org [REST] --> RetailNet["💾 RetailNet"]
    IPS["💾 IPS (SFTP/XML)"] --> S3

    Customer:::userStyle
    Dealer:::userStyle
    HQMarket:::userStyle
    Yves:::web
    Zed:::backend
    MP:::backend
    Glue:::backend
    Import:::backend
    DB:::storage
    Redis:::storage
    ES:::storage
    MQ:::infra
    S3:::storage
    Spryker:::systemStyle
    IParts:::externalStyle
    VIS:::externalStyle
    DIMS:::externalStyle
    IAM:::externalStyle
    CRISP:::externalStyle
    RetailNet:::externalStyle
    IPS:::externalStyle
