%% C2 Container — NORMA (single store, Phase 1). Storefront JS widgets omitted here (see C1 / integration overview);
%% this view focuses on the Spryker runtime containers and backend/ETL/PSP integration edges.
flowchart LR
   subgraph Spryker["NORMA Spryker Platform (single store DE, EUR, de_DE)"]
      Yves["🌐 Yves<br><small>Twig + PHP</small><br><small>Storefront incl. custom Returns Portal</small>"]
      BackOffice["🏢 Back Office<br><small>Twig + PHP</small><br><small>Admin UI</small>"]
      BackendAPI["⚙️ Glue Backend API<br><small>PHP</small><br><small>Data Exchange / migration import+export</small>"]
      BackendGateway["🚪 Backend Gateway<br><small>PHP</small><br><small>Zed RPC</small>"]
      MySQL["🗄️ MariaDB<br><small>Single relational database</small>"]
      Redis["⚡ Redis<br><small>KV storage & sessions</small>"]
      OpenSearch["🔍 OpenSearch/ES<br><small>Category PLP search index</small>"]
      RabbitMQ["📬 RabbitMQ<br><small>Message broker (events, sync, MessageBroker)</small>"]
      Jenkins["⏰ Scheduler<br><small>Jenkins + PHP</small><br><small>P&S, import cron, OMS cron</small>"]
   end

   Customer["👤 Customer"] -- Browse, buy, return<br>[HTTPS] --> Yves
   BackofficeUser["👤 Back Office User"] -- Manage<br>[HTTPS] --> BackOffice
   Yves -- Requests<br>[HTTPS] --> BackendGateway
   Yves -- Sessions, cache<br>[TCP] --> Redis
   Yves -- Category PLP search<br>[REST] --> OpenSearch
   BackendGateway -- Read/Write<br>[SQL] --> MySQL
   BackOffice -- Read/Write<br>[SQL] --> MySQL
   BackendAPI -- Read/Write<br>[SQL] --> MySQL
   Jenkins -- Jobs --> Jenkins
   Jenkins -- Events/Sync<br>[AMQP] --> RabbitMQ
   Jenkins -- Read/Write<br>[SQL] --> MySQL
   Jenkins -- Populate KV<br>[TCP] --> Redis
   Jenkins -- Index<br>[REST] --> OpenSearch
   MySQL -- Trigger events<br>[AMQP] --> RabbitMQ
   RabbitMQ -- P&S<br>[AMQP] --> Jenkins

   %% Backend / ETL / PSP edges
   Talend["🔁 Talend ETL"] -- Delta product/price/stock import<br>~50 products / 10 min<br>[Glue Backend API] --> BackendAPI
   BackendAPI -- Delta orders + payments export<br>every 10 min --> Talend
   Talend <-- Products/orders --> Plentymarkets["💾 Plentymarkets ERP"]
   Yves -- Payment redirect<br>[HTTPS] --> Payone["💳 Payone PSP"]
   Payone -- Capture/status events<br>[MessageBroker] --> RabbitMQ
   Jenkins -- Return-label request<br>[REST] --> Carriers["📦 DHL / DPD / GLS"]
   Jenkins -- Product feed<br>[REST] --> Feed["🗂️ Feed Dynamix"]
   Jenkins -- Customer info<br>[REST] --> Emarsys["✉️ Emarsys CRM"]
   MySQL -- BI extract<br>[site2site VPN / Data Exchange API] --> DWH["📈 DWH"]

   Yves:::webAppStyle
   BackOffice:::webAppStyle
   BackendAPI:::apiStyle
   BackendGateway:::infraStyle
   MySQL:::storageStyle
   Redis:::storageStyle
   OpenSearch:::storageStyle
   RabbitMQ:::infraStyle
   Jenkins:::infraStyle
   Customer:::userStyle
   BackofficeUser:::userStyle
   Talend:::apiStyle
   Plentymarkets:::externalStyle
   Payone:::apiStyle
   Carriers:::externalStyle
   Feed:::apiStyle
   Emarsys:::apiStyle
   DWH:::externalStyle
