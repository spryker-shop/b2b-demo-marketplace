%% C3 Component — NORMA custom domains (Zed-centric): ERP Integration, Feed Generation, Returns Portal.
%% Shows how custom project modules attach to core Spryker modules (Glue Backend API, DataImport, OMS,
%% Return Management, Payment) via facades/plugins.
flowchart TB
    subgraph ErpDomain["ERP Integration Domain (custom)"]
        DeltaImporter["DeltaImportProcessor<br><small>Business model: cursor + idempotency</small>"]
        ImportWriters["Batch DataSet Writers<br><small>Product / Price / Stock (CTE, bulk)</small>"]
        OrderExporter["OrderPaymentExporter<br><small>Delta export cursor</small>"]
    end
    subgraph FeedDomain["Feed Generation Domain (custom)"]
        FeedBuilder["ProductFeedBuilder<br><small>API-based product export</small>"]
    end
    subgraph ReturnsDomain["Returns Portal Domain (custom)"]
        ReturnsController["Yves Returns Controller<br><small>customer returns portal</small>"]
        ReturnLabelCommand["OMS ReturnLabelCommand<br><small>calls DHL/DPD/GLS</small>"]
    end

    subgraph Core["Core Spryker Modules"]
        GlueBackend["Glue Backend API<br><small>Data Exchange / custom resources</small>"]
        DataImport["DataImport + Publish&Sync"]
        SalesReturn["Return Management (OMS sub-process)"]
        Oms["OMS / StateMachine"]
        Payment["Payment (direct Payone module)"]
        ProductPS["Product / Price / Stock Storage"]
    end

    Talend["🔁 Talend ETL"] --> GlueBackend
    GlueBackend --> DeltaImporter
    DeltaImporter --> ImportWriters
    ImportWriters --> DataImport
    DataImport --> ProductPS
    OrderExporter --> GlueBackend
    Oms --> OrderExporter

    FeedBuilder --> ProductPS
    FeedBuilder --> Feed["🗂️ Feed Dynamix"]

    ReturnsController --> SalesReturn
    SalesReturn --> Oms
    Oms --> ReturnLabelCommand
    ReturnLabelCommand --> Carriers["📦 DHL / DPD / GLS"]

    Payment --> Oms

    DeltaImporter:::businessStyle
    ImportWriters:::persistenceStyle
    OrderExporter:::businessStyle
    FeedBuilder:::businessStyle
    ReturnsController:::presentationStyle
    ReturnLabelCommand:::businessStyle
    GlueBackend:::apiStyle
    DataImport:::communicationStyle
    SalesReturn:::businessStyle
    Oms:::businessStyle
    Payment:::businessStyle
    ProductPS:::persistenceStyle
    Talend:::externalStyle
    Feed:::externalStyle
    Carriers:::externalStyle
    classDef presentationStyle fill:#27AE60,stroke:#27ae60,stroke-width:2px,color:#fff
    classDef communicationStyle fill:#E67E22,stroke:#d68910,stroke-width:2px,color:#fff
    classDef businessStyle fill:#2980B9,stroke:#2980b9,stroke-width:2px,color:#fff
    classDef apiStyle fill:#2980B9,stroke:#2980b9,stroke-width:2px,color:#fff
    classDef persistenceStyle fill:#9B59B6,stroke:#8e44ad,stroke-width:2px,color:#fff
    classDef externalStyle fill:#95A5A6,stroke:#7f8c8d,stroke-width:2px,color:#fff
