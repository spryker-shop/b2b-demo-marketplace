%% C3 Component — Scania custom integration domains (POC)
%% Focus: the project-level modules that make Scania different from OOTB Spryker.
%% Each custom module follows the Spryker Client (external HTTP) + Zed (facade/business) split.
---
config:
  layout: elk
---
flowchart TB
    subgraph Auth["🔐 ScaniaCiamAuth (Yves + Zed)"]
        direction TB
        CiamPlugins["Federated Auth plugin chain<br><small>AuthenticationLink → ClientStrategy →<br>IdentityStrategy → IdentityPersistence</small>"]
        CiamJit["JIT Customer Provisioner<br><small>maps claims → Customer + Company User</small>"]
        RoleMapper["CIAM Role Mapper<br><small>CIAM role → Company Role (ACL)</small>"]
    end
    subgraph Asset["🚛 ScaniaFmatAsset (Client + Zed)"]
        direction TB
        FmatClient["FMAT Client<br><small>HTTP adapter, paginated fetch</small>"]
        AssetReader["Asset Reader (live fetch)<br><small>no caching for POC</small>"]
        AssetWidget["Asset selection UI<br><small>Yves list + selector</small>"]
    end
    subgraph Catalog["📋 ScaniaSecmService (Client + Zed)"]
        direction TB
        SecmClient["SECM Client<br><small>HTTP adapter</small>"]
        ServiceReader["Service Reader<br><small>compatible services + price per vehicle</small>"]
    end
    subgraph Details["📦 ScaniaSpisaDetail (Client + Zed)"]
        direction TB
        SpisaClient["PIM-SPISA Client<br><small>HTTP adapter</small>"]
        DetailExpander["Detail Expander<br><small>description, images; config payload (SD-002)</small>"]
    end
    subgraph Cart["🛒 ScaniaDynamicService (Zed)"]
        direction TB
        CartExpander["Cart Item Expander<br><small>inject dynamic service + SECM price</small>"]
        PriceLock["Price Lock plugin<br><small>lock SECM price at add-to-cart</small>"]
    end
    subgraph OMS["📬 ScaniaFmatOrderNotify (Zed)"]
        direction TB
        NotifyCmd1["OMS Command: Order-Created notify<br><small>POST FMAT #1</small>"]
        NotifyCmd2["OMS Command: Payment+Activation notify<br><small>POST FMAT #2 (Future)</small>"]
    end

    Core["🟠 Spryker Core<br><small>Customer, Company, Cart, Checkout,<br>Sales, OMS, ConfigurableProduct, SSP</small>"]

    CiamPlugins --> CiamJit --> RoleMapper --> Core
    AssetWidget --> AssetReader --> FmatClient
    AssetReader --> Core
    ServiceReader --> SecmClient
    ServiceReader --> Core
    DetailExpander --> SpisaClient
    DetailExpander --> Core
    CartExpander --> PriceLock
    CartExpander --> Core
    Core --> NotifyCmd1
    Core --> NotifyCmd2
    NotifyCmd1 --> FmatClient
    NotifyCmd2 --> FmatClient

    Auth:::authStyle
    Asset:::apiStyle
    Catalog:::apiStyle
    Details:::apiStyle
    Cart:::businessStyle
    OMS:::businessStyle
    Core:::systemStyle
    classDef authStyle fill:#e1f5ff,stroke:#0366d6,stroke-width:2px
    classDef apiStyle fill:#2980B9,stroke:#2980b9,stroke-width:2px,color:#fff
    classDef businessStyle fill:#27AE60,stroke:#27ae60,stroke-width:2px,color:#fff
    classDef systemStyle fill:#E67E22,stroke:#c0392b,stroke-width:3px,color:#fff
