%% C3 Component — Daimler custom domains (project-level modules on top of Spryker core)
%% Shows the custom/extended modules that carry the Daimler-specific behaviour and the core
%% Spryker features they build on (per research-docs.md).
---
config:
  layout: elk
---
flowchart TB
    subgraph Storefront["🌐 Yves Storefront (custom + extended)"]
        ExtSearchClient["ExternalCatalogSearch<br><small>QueryInterface impl → external API</small>"]
        AvailabilityWidget["AvailabilityWidget<br><small>TruckLog / MB LogBus lookup</small>"]
        VinSearch["VinPartSearch<br><small>VIS FIN/VIN + UK licence-plate</small>"]
        DealerSelect["DealerSelection<br><small>active-dealer scoping of prices/products</small>"]
    end

    subgraph MerchantDomain["🏪 Dealer / Merchant Domain (Zed + MP)"]
        MerchantRel["MerchantB2bContracts (core)<br><small>dealer↔customer relation</small>"]
        ProdRestrict["MerchantProductRestriction (core)<br><small>per-customer product lists</small>"]
        CustApproval["CustomerApprovalRequest (custom)<br><small>registration-request → approve/reject</small>"]
        DealerHierarchy["DealerBranchHierarchy (custom)<br><small>main instance + branches, shared prices</small>"]
        MerchantPrice["MerchantSpecificPrice (custom)<br><small>discount groups per customer/product</small>"]
    end

    subgraph MarketDomain["🏢 Market / HQ Domain (Zed BO)"]
        PersistenceAcl["PersistenceAcl (core)<br><small>per-market row-level isolation</small>"]
        BoUserRoles["User + ACL (core)<br><small>branch/market BO roles</small>"]
        HqMonitor["HqMonitoring (custom)<br><small>import status, dumps, revenue, legal</small>"]
        LegalTemplates["MarketLegalTemplate (custom)<br><small>T&amp;C/warranty per market, fallback</small>"]
    end

    subgraph ImportDomain["⏰ Import &amp; Sync Domain (Zed console + P&S)"]
        XmlImporter["XmlPartsImporter (custom)<br><small>S3 XML → CTE bulk import</small>"]
        ImportTracker["ImportExecutionTracker (custom)<br><small>type, created/finished, success</small>"]
        PriceImporter["PriceImporter (custom)<br><small>LLP + discount classes, CTE</small>"]
        PublishSync["Publish &amp; Sync (core, tuned)<br><small>chunked, event triggerBulk</small>"]
    end

    subgraph OrderComms["💬 Order Communication"]
        Comments["Comments + OMS (core)<br><small>customer↔dealer order dialog</small>"]
        Oms["OMS / StateMachine (core)<br><small>Invoice-only order process</small>"]
    end

    DealerSelect --> MerchantRel
    MerchantRel --> ProdRestrict
    CustApproval --> MerchantRel
    DealerHierarchy --> MerchantRel
    MerchantPrice --> MerchantRel
    HqMonitor --> ImportTracker
    XmlImporter --> ImportTracker
    XmlImporter --> PublishSync
    PriceImporter --> PublishSync
    ExtSearchClient -.-> ProdRestrict
    Comments --> Oms
    BoUserRoles --> PersistenceAcl

    ExtSearchClient:::custom
    AvailabilityWidget:::custom
    VinSearch:::custom
    DealerSelect:::custom
    CustApproval:::custom
    DealerHierarchy:::custom
    MerchantPrice:::custom
    HqMonitor:::custom
    LegalTemplates:::custom
    XmlImporter:::custom
    ImportTracker:::custom
    PriceImporter:::custom
    MerchantRel:::core
    ProdRestrict:::core
    PersistenceAcl:::core
    BoUserRoles:::core
    PublishSync:::core
    Comments:::core
    Oms:::core

    classDef custom fill:#2980B9,stroke:#2980b9,stroke-width:2px,color:#fff
    classDef core fill:#9B59B6,stroke:#8e44ad,stroke-width:2px,color:#fff
