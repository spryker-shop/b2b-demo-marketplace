flowchart TB
    subgraph Yves["🌐 Yves (Storefront)"]
        AssetPage["AssetSelectionController<br><small>lists fleet vehicles</small>"]
        ServiceCatalogPage["ServiceCatalogController<br><small>compatible services per vehicle</small>"]
        ServiceDetailPage["ServiceDetailController<br><small>service description + images</small>"]
        CartCheckout["Cart & Checkout Widgets<br><small>OOTB + dynamic service item</small>"]
    end

    subgraph Client["🔗 Client Layer (project)"]
        FmatAssetClient["FmatAssetClient<br><small>live paginated asset fetch</small>"]
        SecmCatalogClient["SecmServiceCatalogClient<br><small>services + prices</small>"]
        SpisaDetailClient["SpisaServiceDetailClient<br><small>service details / configurator params</small>"]
    end

    subgraph Zed["🏢 Zed (Business + Persistence + OMS)"]
        CiamStrategy["CiamOauthCustomerAuthenticationStrategyPlugin<br><small>JIT customer create + role→CompanyRole map</small>"]
        DynServiceModel["DynamicServiceCartExpander / PriceModel<br><small>add API-priced service to cart (SD-001)</small>"]
        OmsCommands["FMAT OMS Commands<br><small>OrderCreatedNotification (POC),<br>PaymentActivationNotification (future)</small>"]
        MailCommand["OrderConfirmationMail OMS command<br><small>OOTB</small>"]
        SalesRepo["Sales / Company / CompanyRole<br><small>OOTB persistence</small>"]
    end

    subgraph External["External systems (REST — protocol TBD)"]
        CIAM["🔐 CIAM"]
        FMAT["🚚 FMAT"]
        SECM["🧰 SECM"]
        PIMSPISA["📦 PIM-SPISA"]
        SMTP["✉️ SMTP"]
    end

    AssetPage --> FmatAssetClient --> FMAT
    ServiceCatalogPage --> SecmCatalogClient --> SECM
    ServiceDetailPage --> SpisaDetailClient --> PIMSPISA
    CartCheckout --> DynServiceModel
    CiamStrategy --> CIAM
