<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="CmsBlock">
        <property name="customerGroups" type="CustomerGroupCollection" singular="customerGroup"/>
        <property name="isRestricted" type="bool"/>
    </transfer>

    <transfer name="CmsBlockValidationRequest" strict="true">
        <property name="cmsBlock" type="CmsBlock"/>
        <property name="customer" type="Customer"/>
    </transfer>

    <transfer name="CmsBlockValidationResponse" strict="true">
        <property name="isValid" type="bool"/>
    </transfer>

</transfers>
