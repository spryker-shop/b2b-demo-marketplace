{% extends view('cart-update', '@SprykerShop:MultiCartPage') %}

{% block customerContent %}
    {% include molecule('action-bar') with {
        modifiers: ['first', 'middle'],
        data: {
            title: 'multi_cart.form.edit' | trans ~ '«' ~ data.form.vars.value.name ~ '»',
        },
    } only %}

    <div class="grid cart-update">
        <div class="col col--sm-12 col--lg-6">
            {% include molecule('form') with {
                data: {
                    form: data.form,
                    options: {
                        action: data.formAction,
                    },
                    submit: {
                        enable: true,
                        class: 'form__action--expand-sm-md button button--success',
                        text: 'cart_note.form.save' | trans,
                    },
                    cancel: {
                        enable: true,
                        url: data.backUrl,
                        icon: null,
                        class: 'form__action--expand-sm-md button button--secondary button--hollow',
                        text: 'general.back.button' | trans,
                    },
                },
            } only %}
        </div>
    </div>
{% endblock %}
