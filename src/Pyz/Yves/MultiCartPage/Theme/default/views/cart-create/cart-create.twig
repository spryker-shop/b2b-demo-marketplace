{% extends view('cart-create', '@SprykerShop:MultiCartPage') %}

{% block customerContent %}
    {% include molecule('action-bar') with {
        modifiers: ['first', 'middle'],
        data: {
            title: 'page.multi_cart.shopping_cart.create.title' | trans,
        },
    } only %}

    {% include molecule('form') with {
        data: {
            form: data.form,
            options: {
                action: data.formAction,
            },
            submit: {
                enable: true,
                class: 'form__action--expand-sm-md button button--success',
            },
            cancel: {
                enable: true,
                url: data.backUrl,
                class: 'form__action--expand-sm-md button button--secondary button--hollow',
                text: 'general.back.button' | trans,
                icon: null,
            },
        },
    } only %}
{% endblock %}
