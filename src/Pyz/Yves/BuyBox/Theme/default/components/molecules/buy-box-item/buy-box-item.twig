{% extends molecule('buy-box-item', '@SprykerFeature:BuyBox') %}

{% block body %}
    <div class="grid grid--nowrap grid--gap-smaller">
        {% block itemInner %}
            {{ parent() }}
        {% endblock %}
    </div>
{% endblock %}

{% block merchantInfoCol %}
    <div class="col col--expand">
        {% block merchantName %}
            <div class="{{ config.name }}__name">{{ data.merchantName }}</div>
        {% endblock %}

        <div class="{{ config.name }}__links">
            {% block merchantLink %}
                <a class="{{ config.name }}__link" href="{{ functionExists('generatePath') ? generatePath(data.merchantUrl) : data.merchantUrl }}">
                    {{ 'buy_box.view_merchant' | trans }}
                </a>
            {% endblock %}

            {% block merchantRelationRequestCreateButton %}
                {% if data.merchantReference is not null %}
                    {% widget 'MerchantRelationRequestCreateLinkWidget' args [data.merchantReference] only %}{% endwidget %}
                {% endif %}
            {% endblock %}
        </div>
    </div>
{% endblock %}


{% block price %}
    <div class="spacing-bottom">
        {% widget 'CurrentProductPriceVolumeWidget' args [data.price] only %}
            {% block priceTable %}{% endblock %}
            {% block price %}
                {% embed molecule('volume-price', 'PriceProductVolumeWidget') with {
                    class: 'grid grid--gap-smaller grid--right',
                    modifiers: ['list'],
                    attributes: {
                        'data-json': jsonVolumeProductPrices | json_encode(),
                    },
                    data: {
                        amount: data.amount,
                        originalAmount: data.originalAmount,
                    },
                } only %}
                    {% block body %}
                        <div class="col is-hidden-sm-md">
                            {{ block('priceModeWrap') }}
                        </div>
                        <div class="col text-right">
                            {{ block('amount') }}
                            {{ block('originalAmount') }}
                        </div>
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% nowidget %}
            {{ parent() }}
        {% endwidget %}
    </div>
{% endblock %}
