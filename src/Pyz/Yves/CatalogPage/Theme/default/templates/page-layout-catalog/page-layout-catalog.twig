{% extends template('page-layout-catalog', '@SprykerShop:CatalogPage') %}

{% block contentClass %}page-layout-main page-layout-main--catalog-page{% endblock %}

{% block pageInfo %}
    <div class="page-info">
        <div class="container">
            {{ block('breadcrumbs') }}
        </div>
    </div>
{% endblock %}

{% block content %}
    {% include molecule('skip-link') with {
        data: {
            href: catalogProductListId,
            text: 'global.skip-to-products' | trans,
        },
    } only %}

    {% set catalogJsName = 'js-catalog' %}

    {% include molecule('window-location-applicator', 'CatalogPage') with {
        attributes: {
            'form-class-name': catalogJsName ~ '__form',
            'trigger-class-name': catalogJsName ~ '__trigger',
            'sort-trigger-class-name': catalogJsName ~ '__sort-trigger',
        },
    } only %}

    <form method="GET" class="grid grid--gap page-layout-main__catalog-page-content js-form-input-default-value-disabler__catalog-form {{ catalogJsName }}__form">
        {% block form %}
            {% include molecule('form-input-default-value-disabler') with {
                class: 'is-hidden',
                attributes: {
                    'form-selector': '.js-form-input-default-value-disabler__catalog-form',
                    'input-selector': '.js-form-input-default-value-disabler__catalog-input',
                },
            } only %}

            <button type="submit" class="is-hidden" tabindex="-1" aria-hidden="true"></button>

            {% include molecule('form-submitter') with {
                class: 'is-hidden',
                attributes: {
                    'trigger-selector': '.filter-section .checkbox__input, .filter-section .radio__input, .filter-section .js-rating-selector__input',
                    event: 'change',
                },
            } only %}

            <div class="col col--sm-12 col--lg-4 col--xl-3">
                {% block filterBar %}
                    {% block filterBarAsset %}
                        {% widget 'SspAssetFilterWidget' only %}{% endwidget %}
                    {% endblock %}

                    <button class="button button--justify catalog-filter-trigger js-catalog-filters-trigger is-hidden-lg-xxl spacing-bottom spacing-bottom--big">
                        {{ 'catalog.filter.and.sorting.button' | trans }}
                        {% include atom('font-icon') with {
                            data: {
                                name: 'tune',
                            },
                        } only %}
                    </button>

                    {% include molecule('toggler-click') with {
                        attributes: {
                            'trigger-class-name': 'js-catalog-filters-trigger',
                            'target-class-name': 'js-filter-section',
                            'class-to-toggle': 'is-hidden-sm-md',
                        },
                    } only %}

                    {% include molecule('sticky-body-toggler') with {
                        attributes: {
                            'trigger-class-name': 'js-catalog-filters-trigger',
                            'class-to-fix-body': 'is-locked-mobile',
                        },
                    } only %}

                    {% block filterBarActiveFilters %}
                        {% include organism('active-filter-section', 'CatalogPage') with {
                            data: {
                                facets: data.facets,
                                filteredFacets: data.filteredFacets,
                                numFound: data.pagination.numFound | default(0),
                            },
                        } only %}
                    {% endblock %}

                    {% include organism('filter-section', 'CatalogPage') with {
                        class: 'is-hidden-sm-md',
                        data: {
                            facets: data.facets,
                            filteredFacets: data.filteredFacets,
                            filterPath: data.filterPath,
                            categories: data.categories,
                            isEmptyCategoryFilterValueVisible: data.isEmptyCategoryFilterValueVisible,
                            parentJsName: catalogJsName,
                            numberFormatConfig: numberFormatConfig,
                        },
                    } only %}
                {% endblock %}
            </div>

            <div class="col col--sm-12 col--lg-8 col--xl-9" id="{{ catalogProductListId }}">
                {% block resultHeader %}
                    {% embed molecule('catalog-header', 'CatalogPage') with {
                        data: {
                            title: data.title,
                            numFound: data.pagination.numFound | default(0),
                            pagination: data.pagination,
                            sort: data.sort,
                            viewMode: data.viewMode,
                            parentJsName: catalogJsName,
                        },
                    } only %}
                        {% block controls %}
                            {% include molecule('sort', 'CatalogPage') with {
                                data: {
                                    pagination: data.pagination,
                                    sort: data.sort,
                                    parentJsName: data.parentJsName,
                                },
                            } only %}

                            {% include molecule('view-mode-switch', 'CatalogPage') with {
                                data: {
                                    viewMode: data.viewMode,
                                },
                            } only %}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}

                <div class="grid grid--stretch grid--gap-small">
                    {% if data.products %}
                        {% for product in data.products %}
                            {% widget 'CatalogPageProductWidget' args [
                                product,
                                data.viewMode,
                                data.products,
                            ] only %}
                            {% endwidget %}
                        {% endfor %}
                    {% else %}
                        {% block noResults %}
                            {% set hasSuggestion = data.suggestion is defined and data.suggestion is not empty %}

                            <div class="col col--sm-12">
                                {% include molecule('empty-state', 'CatalogPage') with {
                                    data: {
                                        heading: 'catalog.no-results.title' | trans,
                                        message: 'catalog.no-results.message' | trans,
                                        suggestionLabel: hasSuggestion ? 'global.search.spellingSuggestion' | trans : '',
                                        suggestionTerm: hasSuggestion ? data.suggestion : '',
                                        suggestionUrl: hasSuggestion ? path('search', { q: data.suggestion }) : '',
                                        ctaLabel: hasSuggestion ? ('catalog.no-results.search-for' | trans) ~ ' "' ~ data.suggestion ~ '"' : '',
                                        ctaUrl: hasSuggestion ? path('search', { q: data.suggestion }) : '',
                                        tip: 'catalog.no-results.tip' | trans,
                                    },
                                } only %}
                            </div>
                        {% endblock %}
                    {% endif %}
                </div>

                {% include molecule('pagination') with {
                    data: data.pagination,
                } only %}
            </div>
        {% endblock %}
    </form>
{% endblock %}
