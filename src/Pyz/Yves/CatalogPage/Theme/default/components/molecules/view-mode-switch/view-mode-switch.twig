{% extends model('component') %}

{% define config = {
    name: 'view-mode-switch',
    tag: 'div'
} %}

{% define data = {
    viewMode: null
} %}

{% set gridHref = path('change-view-mode', { mode: 'grid', 'referer-url': app.request.requestUri }) %}
{% set listHref = path('change-view-mode', { mode: 'list', 'referer-url': app.request.requestUri }) %}

{% macro modeLink(name, href, icon, label, isActive) %}
    <a class="{{ name }}__link{% if isActive %} {{ name }}__link--active{% endif %}"
        href="{{ href }}"
        aria-label="{{ label }}"
        {% if isActive %}aria-current="true"{% endif %}>
        {% include atom('font-icon') with {
            data: {
                name: icon,
            },
        } only %}
    </a>
{% endmacro %}

{% block body %}
    {{ _self.modeLink(config.name, gridHref, 'grid_view', 'catalog.view.mode.grid' | trans, data.viewMode == 'grid') }}
    {{ _self.modeLink(config.name, listHref, 'menu', 'catalog.view.mode.list' | trans, data.viewMode != 'grid') }}
{% endblock %}
