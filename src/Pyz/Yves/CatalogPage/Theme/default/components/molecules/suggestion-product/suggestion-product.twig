{% extends molecule('suggestion-product', '@SprykerShop:CatalogPage') %}

{% block body %}
    <a class="link--no-decoration js-suggest-search__item--navigable js-suggest-search__product-item--navigable {{ config.name }}__link" href="{{ functionExists('generatePath') ? generatePath(data.url) : data.url }}">
        {% if data.image %}
            {% block image %}
                {% set imageClasses = config.name ~ '__thumbnail' %}
                {% set imageModifiers = ['thumbnail', 'smaller', 'spaceless', 'with-overlay'] %}

                {{ parent() }}
            {% endblock %}
        {% endif %}

        <span class="{{ config.name }}__name">
            <span class="{{ config.name }}__content">
                <span class="{{ config.name }}__title">
                    {{ data.title }}
                </span>

                {% if data.product.abstract_sku is defined %}
                    <span class="{{ config.name }}__sku">
                        SKU: {{ data.product.abstract_sku }}
                    </span>
                {% endif %}
            </span>

            {% if can('SeePricePermissionPlugin') %}
                {% include molecule('money-price') with {
                    class: config.name ~ '__price',
                    modifiers: ['sm'],
                    data: {
                        amount: data.price,
                        originalAmount: data.originalPrice ?? null,
                    },
                } only %}
            {% endif %}
        </span>
    </a>
{% endblock %}
