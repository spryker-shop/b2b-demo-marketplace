{% extends molecule('sort', '@SprykerShop:CatalogPage') %}

{% block body %}
    <div class="{{ config.name }}__controls">
        <div class="{{ config.name }}__field {{ config.name }}__field--filter">
            <span class="{{ config.name }}__label is-hidden">{{ 'catalog.filter.sort' | trans }}</span>

            {% embed molecule('custom-select') with {
                modifiers: ['sm'],
                attributes: {
                    name: 'sort',
                    'config-theme': 'sm',
                },
                embed: {
                    sort: data.sort,
                    parentJsName: data.parentJsName,
                },
            } only %}
                {% block selectClass %}
                    {{ parent() }} {{ embed.parentJsName }}__sort-trigger
                {% endblock %}
                {% block options %}
                    <option value="">{{ 'catalog.sort.relevance' | trans }}</option>
                    {% for sortParamName in embed.sort.sortParamNames | default([]) %}
                        <option value="{{ sortParamName }}" {% if sortParamName == embed.sort.currentSortParam %}selected{% endif %}>{{ ('catalog.sort.' ~ sortParamName) | trans }}</option>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        </div>

        <div class="{{ config.name }}__field {{ config.name }}__field--per is-hidden-sm-md">
            <span class="{{ config.name }}__label is-hidden">{{ 'catalog.filter.per' | trans }}</span>

            {% embed molecule('custom-select') with {
                modifiers: ['sm'],
                attributes: {
                    name: 'ipp',
                    'config-theme': 'sm',
                },
                embed: {
                    pagination: data.pagination,
                    parentJsName: data.parentJsName,
                },
            } only %}
                {% block selectClass %}
                    {{ parent() }} {{ embed.parentJsName }}__sort-trigger
                {% endblock %}
                {% block options %}
                    {% for limit in embed.pagination.config.validItemsPerPageOptions | default([]) %}
                        <option value="{{ limit }}" {% if limit == embed.pagination.currentItemsPerPage %}selected{% endif %}>{{ limit | executeFilterIfExists('formatInt', app.locale) }}</option>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        </div>
    </div>
{% endblock %}
