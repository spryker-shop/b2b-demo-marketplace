{% extends molecule('schedule-execution-history', '@SprykerFeature:OrderExperienceManagement') %}

{% block wrapper %}
    {% set wrapperClass = "" %}
    {{ parent() }}
{% endblock %}

{% block heading %}
    {% set titleClass = config.name ~ '__title' %}
    {% set contentClass = config.name ~ '__heading-content' %}

    {{ parent() }}
{% endblock %}

{% block table %}
    {% set rows = data.history | map(historyItem => {
        date: historyItem.createdAt | formatDate,
        status: _self.renderStatusCell(historyItem, data.statusClassMap),
        orderReference: historyItem.orderReference ?: '—',
        actions: historyItem.idSalesOrder ? [{
            url: url('customer/order/details', { id: historyItem.idSalesOrder }),
            title: 'recurring_orders.detail.history.view_order',
            icon: 'eye',
            qa: 'recurring-order-history-view-order',
        }] : [],
    }) %}

    {% include molecule('advanced-table') with {
        data: {
            columns: columns,
            rows: rows,
            emptyText: 'recurring_orders.detail.history.empty',
            pagination: historyPagination,
        },
    } only %}
{% endblock %}

{% macro renderStatusCell(historyItem, statusClassMap) %}
    {% include molecule('status') with {
        data: {
            label: ('recurring_orders.history.event.' ~ historyItem.eventType) | trans,
            status: historyItem.eventType,
        },
    } only %}
    
    {% if historyItem.errors is defined and historyItem.errors | length %}
        {% include molecule('schedule-error-popover','OrderExperienceManagement') with {
            data: {
                errors: historyItem.errors,
                orderUid: 'order-uid-' ~ historyItem.orderReference ~ '_' ~ historyItem.idRecurringScheduleHistory,
                createdAt: historyItem.createdAt,
            },
        } only %}
    {% endif %}
{% endmacro %}
