{% extends model('component') %}

{% define config = {
    name: 'header-cart-pill',
    tag: 'header-cart-pill',
} %}

{% define data = {
    quantity: 0,
} %}

{% block body %}
    <a
        href="{{ url('cart') }}"
        class="link--no-decoration cart-trigger {{ config.name }}__trigger {{ config.jsName }}__trigger"
        aria-label="{{ 'header.cart' | trans }}{{ data.quantity > 0 ? ', ' ~ data.quantity ~ ' ' ~ ('header.cart.items' | trans) : '' }}"
        aria-expanded="false"
    >
        <span class="cart-trigger__icon">
            {% include atom('font-icon') with {
                modifiers: ['size-inherit'],
                data: { name: 'shopping_cart' },
            } only %}
        </span>
        {% if data.quantity > 0 %}
            <span class="cart-trigger__badge" aria-hidden="true">{{ data.quantity }}</span>
        {% endif %}
    </a>

    <div class="{{ config.name }}__dropdown {{ config.jsName }}__dropdown" aria-hidden="true">
        {% widget 'MiniCartWidget' args [data.quantity] only %}{% endwidget %}
    </div>
{% endblock %}
