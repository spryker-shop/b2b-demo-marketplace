{% extends organism('side-drawer', '@SprykerShop:ShopUi') %}

{% define attributes = {
    'locked-body-class-name': 'is-locked-tablet',
    'overlay-class-name': 'main-overlay',
    'should-close-by-overlay-click': true,
    'overlay-breakpoint': 1024,
} %}

{% block body %}
    <aside class="{{ config.name }}__drawer">
        <div class="{{ config.name }}__header">
            {% block close %}
                <button class="{{ config.name }}__close" type="button" aria-label="{{ 'header.menu.close' | trans }}">
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
            {% endblock %}

            {% include molecule('logo') with {
                class: config.name ~ '__header-logo',
                modifiers: ['drawer'],
            } only %}

            <a href="{{ url('cart') }}" class="{{ config.name }}__header-cart" aria-label="{{ 'header.cart' | trans }}">
                <span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span>
                {% set cartQuantity = app['cart.quantity'] | default(0) %}
                {% if cartQuantity > 0 %}
                    <span class="{{ config.name }}__header-cart-badge">{{ cartQuantity }}</span>
                {% endif %}
            </a>
        </div>

        <div class="{{ config.name }}__panels">
            <div class="{{ config.name }}__panel {{ config.name }}__panel--active {{ config.jsName }}__panel" data-panel-id="main">
                <div class="{{ config.name }}__content">
                    <div class="{{ config.name }}__zone-search">
                        {% embed molecule('search-form') with {
                            modifiers: ['drawer'],
                            attributes: {
                                'data-search-id': 'mobile',
                            },
                        } only %}
                        {% endembed %}
                    </div>

                    <div class="{{ config.name }}__zone-account">
                        {% if is_granted('ROLE_USER') %}
                            {% set customerFullNameWidget = findWidget('CustomerFullNameWidget') %}
                            {% set customerFullName = customerFullNameWidget.customerFullName | default('') %}

                            {% set menuItemCompanyWidget = findWidget('MenuItemCompanyWidget') %}
                            {% set companyName = menuItemCompanyWidget.companyName | default('') %}

                            {% include molecule('header-dropdown') with {
                                modifiers: ['drawer'],
                                data: {
                                    preset: 'user-account',
                                    userName: customerFullName,
                                    companyName: companyName,
                                    isDrawer: true,
                                    drillDownTarget: 'account-panel',
                                },
                            } only %}
                        {% else %}
                            <div class="{{ config.name }}__guest-auth">
                                <a href="{{ url('login') }}" class="button button--expand {{ config.name }}__guest-auth-btn">{{ 'customer.please_login' | trans }}</a>
                                <a href="{{ url('register') }}" class="button button--hollow button--expand {{ config.name }}__guest-auth-btn">{{ 'customer.signup' | trans }}</a>
                            </div>
                        {% endif %}
                    </div>

                    <div class="{{ config.name }}__zone-browse">
                        <span class="{{ config.name }}__zone-label">{{ 'header.drawer.browse' | trans }}</span>

                        <div class="{{ config.name }}__browse-list">
                            {% block navigation %}
                                {% widget 'NavigationWidget' args ['MAIN_NAVIGATION', 'navigation-main'] only %}{% endwidget %}
                            {% endblock %}
                        </div>

                        <hr class="divider {{ config.name }}__zone-divider">
                    </div>

                    {% if is_granted('ROLE_USER') %}
                        <div class="{{ config.name }}__zone-quick-links">
                            <a href="{{ url('shopping-list') }}" class="{{ config.name }}__quick-link-row">
                                <span>{{ 'customer.account.shopping_list' | trans }}</span>
                                <span class="material-symbols-outlined {{ config.name }}__row-chevron" aria-hidden="true">chevron_right</span>
                            </a>

                            {% if can('SeeCompanyMenuPermissionPlugin') %}
                                {% include molecule('header-dropdown') with {
                                    modifiers: ['drawer'],
                                    data: {
                                        preset: 'self-service',
                                        isDrawer: true,
                                        drillDownTarget: 'ssp-panel',
                                    },
                                } only %}
                            {% endif %}

                            <a href="{{ url('quick-order') }}" class="{{ config.name }}__quick-link-row">
                                <span>{{ 'quick-order.page-title' | trans }}</span>
                                <span class="material-symbols-outlined {{ config.name }}__row-chevron" aria-hidden="true">chevron_right</span>
                            </a>

                            <hr class="divider {{ config.name }}__zone-divider">
                        </div>
                    {% endif %}

                    <div class="{{ config.name }}__zone-preferences">
                        {% if can('SeePricePermissionPlugin') %}
                            <div class="{{ config.name }}__preference-row">
                                {% widget 'PriceModeSwitcherWidget' only %}{% endwidget %}
                                <span class="material-symbols-outlined {{ config.name }}__row-chevron" aria-hidden="true">chevron_right</span>
                            </div>
                            <div class="{{ config.name }}__preference-row">
                                {% widget 'CurrencyWidget' only %}{% endwidget %}
                                <span class="material-symbols-outlined {{ config.name }}__row-chevron" aria-hidden="true">chevron_right</span>
                            </div>
                        {% endif %}

                        <div class="{{ config.name }}__preference-row">
                            {% widget 'LanguageSwitcherWidget' args [app.request.pathInfo, app.request.queryString, app.request.requestUri] only %}{% endwidget %}
                            <span class="material-symbols-outlined {{ config.name }}__row-chevron" aria-hidden="true">chevron_right</span>
                        </div>

                        {% widget 'StoreSwitcher' with {
                            embed: {
                                configName: config.name,
                            },
                        } only %}
                            {% block body %}
                                <div class="{{ embed.configName }}__preference-row">
                                    {{ parent() }}
                                    <span class="material-symbols-outlined {{ embed.configName }}__row-chevron" aria-hidden="true">chevron_right</span>
                                </div>
                            {% endblock %}
                        {% endwidget %}
                    </div>

                    {% if is_granted('ROLE_USER') %}
                        <div class="{{ config.name }}__zone-logout">
                            <a href="{{ url('logout') }}" class="button button--hollow button--expand">{{ 'customer.logout' | trans }}</a>
                        </div>
                    {% endif %}
                </div>
            </div>

            {% if is_granted('ROLE_USER') %}
                <div class="{{ config.name }}__panel {{ config.jsName }}__panel" data-panel-id="account-panel">
                    <div class="{{ config.name }}__content">
                        <div class="{{ config.name }}__panel-body">
                            {% include molecule('header-dropdown') with {
                                data: {
                                    preset: 'user-account',
                                    panelOnly: true,
                                },
                            } only %}
                        </div>
                    </div>
                </div>
            {% endif %}

            {% if is_granted('ROLE_USER') and can('SeeCompanyMenuPermissionPlugin') %}
                <div class="{{ config.name }}__panel {{ config.jsName }}__panel" data-panel-id="ssp-panel">
                    <div class="{{ config.name }}__content">
                        <div class="{{ config.name }}__panel-body">
                            {% include molecule('header-dropdown') with {
                                data: {
                                    preset: 'self-service',
                                    panelOnly: true,
                                },
                            } only %}
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </aside>
{% endblock %}
