{% extends molecule('configured-bundle', '@SprykerShop:ConfigurableBundleWidget') %}

{% define data = {
    isQuantityVisible: true,
} %}

{%- block extraClass %}{% endblock -%}

{% block body %}
    {% block bundle %}
        {{ parent() }}
    {% endblock %}

    {% block bundleProductList %}
        {{ parent() }}
    {% endblock %}

    {% set bundleActionClassName = 'float-right spacing-y' %}
    <div class="{{ config.name }}__actions">
        <div class="col col--sm-12 col--xl-5">
            {% block configurableBundleNote %}
                {{ parent() }}
            {% endblock %}
        </div>
    </div>
{% endblock %}

{% block notEditableConfigurableBundleNote %}
    {% include molecule('cart-configured-bundle-item-note', 'ConfigurableBundleNoteWidget') ignore missing with {
        data: {
            canWrite: false,
            note: data.bundle.note,
        },
    } only %}
{% endblock %}

{% block bundleInner %}
    {% block bundleGeneralInformation %}
        {% block bundleName %}
            <h6 class="{{ config.name }}__title">
                {%- block bundleNameText -%}
                    {{ parent() }}
                {%- endblock -%}
            </h6>
        {% endblock %}
    {% endblock %}

    {% block bundleQuantity %}
        {% if data.isQuantityVisible %}
            <div class="{{ config.name }}__col {{ config.name }}__col--displaced">
                {% block bundleQuantityInner %}
                    {{ parent() }}
                {% endblock %}
            </div>
        {% endif %}
    {% endblock %}

    {% block bundlePriceInformation %}
        <div class="{{ config.name }}__price">
            {% block bundleTotal %}
                {{ parent() }}
            {% endblock %}
        </div>
    {% endblock %}

    {% block bundleActions %}
        {% if data.isEditable %}
            {% block bundleActionsInner %}
                <form method="POST" action="{{ path(data.ajaxTriggerAttribute ? 'cart/configured-bundle/async/remove' : 'cart/configured-bundle/remove', {'configuredBundleGroupKey': data.bundle.groupKey}) }}">
                    <input type="hidden" name="configured_bundle_remove_item_form[_token]" value="{{ csrf_token('configured_bundle_remove_item_form') }}">
                    <button {{ data.ajaxTriggerAttribute }} data-init-single-click class="{{ config.name }}__remove">
                        {% block removeLinkInner %}
                            {% include atom('font-icon') with {
                                modifiers: ['size-inherit'],
                                data: {
                                    name: 'delete_outline',
                                },
                            } only %}
                        {% endblock %}

                        <span class="{{ config.name }}__remove-tooltip" role="tooltip" aria-hidden="true">{{ 'Remove item from cart' | trans }}</span>
                    </button>
                </form>
            {% endblock %}
        {% endif %}
    {% endblock %}
{% endblock %}

{%- block bundleTotalInner -%}
    {% block bundleTotalValue -%}
        {{ parent() }}
    {%- endblock -%}
{%- endblock -%}
