{% extends molecule('product-configurator', '@SprykerShop:ProductDetailPage') %}

{% set isProductConcrete = data.product.idProductConcrete is not empty %}
{% set sspServiceDetectorWidget = findWidget('SspServiceDetectorWidget', [data.product]) %}
{% set buyBoxWidget = findWidget('BuyBoxWidget', [data.product, app.request]) %}
{% set productOffersCount = buyBoxWidget.products | length %}
{% set showProductAvailability = isProductConcrete and productOffersCount == 0 %}
{% set isAvailable = isProductConcrete and (data.product.available or productOffersCount) %}
{% set hasConfigurableAttributes = data.product.attributeMap.superAttributes is defined and data.product.attributeMap.superAttributes is not empty %}

{% block body %}
    <div class="{{ config.name }}__top-block">
        {% if brand is not empty %}
            <span itemprop="brand" class="{{ config.name }}__brand-name">{{ brand }}</span>
        {% endif %}

        <div class="{{ config.name }}__meta-row">
            <span class="{{ config.name }}__sku">{{ 'product.attribute.sku' | trans }}: <span itemprop="sku">{{ sku }}</span></span>

            {% widget 'ProductDetailPageReviewWidget' args [data.product.idProductAbstract] use view('pdp-review-rating', 'ProductReviewWidget') only %}{% endwidget %}

            {% if isProductConcrete and not isAvailable %}
                <span class="{{ config.name }}__stock-badge {{ config.name }}__stock-badge--out-of-stock" {{ qa('product-stock-badge') }}>
                    {{ 'product.detail.out_of_stock_label' | trans }}
                </span>
            {% endif %}
        </div>
    </div>

    {% set isDisabled = isDisabled or not data.product.available %}
    {% set isAddToCartDisabled = isProductConcrete and isDisabled %}

    {% if can('SeePricePermissionPlugin') %}
        <div class="{{ config.name }}__price-block">
            {% if (sspServiceDetectorWidget and sspServiceDetectorWidget.isService) %}
                {% widget 'SspProductOfferPriceWidget' args [data.product] only %}{% endwidget %}
            {% else %}
                {% widget 'CurrentProductPriceVolumeWidget' args [data.product.currentProductPrice] only %}
                {% elsewidget 'ProductPriceVolumeWidget' args [data.product] only %} {# @deprecated Use CurrentProductPriceVolumeWidget instead. #}
                {% nowidget %}
                    {% include molecule('money-price') with {
                        modifiers: ['row', 'big', 'detail'],
                        data: {
                            amount: data.product.price,
                            originalAmount: data.product.prices.ORIGINAL ?? null,
                        },
                    } only %}
                {% endwidget %}
            {% endif %}
        </div>
    {% endif %}

    {% if showProductAvailability %}
        <div class="{{ config.name }}__availability">
            {% widget 'ProductAvailabilityWidget' args [data.product] only %}{% endwidget %}
        </div>
    {% endif %}

    {% block bundleProducts %}
        {% widget 'ProductBundleProductDetailPageItemsListWidget' args [data.product] only %}{% endwidget %}
    {% endblock %}

    {% block colors %}
        {% widget 'ProductGroupColorWidget' args [data.product.idProductAbstract, data.product.selectedAttributes ?? []] use view('product-detail-color-selector', 'ProductGroupWidget') only %}{% endwidget %}
    {% endblock %}

    {% if hasConfigurableAttributes %}
        <p class="{{ config.name }}__section-title">{{ 'product.detail.configure_product' | trans }}</p>
        <div class="{{ config.name }}__config">
            {% include molecule('variant-configurator', 'ProductDetailPage') with {
                data: {
                    superAttributes: data.product.attributeMap.superAttributes,
                    selectedAttributes: data.product.selectedAttributes,
                    availableAttributes: data.product.availableAttributes,
                },
            } only %}
        </div>
    {% endif %}

    {% widget 'ProductConfigurationProductViewDisplayWidget' args [data.product] only %}{% endwidget %}
    {% widget 'ProductConfigurationProductDetailPageButtonWidget' args [data.product] only %}{% endwidget %}

    {% widget 'AddToCartFormWidget' args [config, data.product, isDisabled, options] with {
        data: {
            isService: sspServiceDetectorWidget and sspServiceDetectorWidget.isService,
            isDisabled: isDisabled,
        },
        embed: {
            showProductAvailability: showProductAvailability,
            buyBoxWidget: buyBoxWidget,
            isAddToCartDisabled: isAddToCartDisabled,
        },
    } only %}
        {% block embeddedData %}
            {% set shipmentTypeServicePointSelectorWidget = findWidget('SspShipmentTypeServicePointSelectorWidget', [data.product, data.isDisabled]) %}

            {% if not shipmentTypeServicePointSelectorWidget %}
                {% set shipmentTypeServicePointSelectorWidget = findWidget('ShipmentTypeServicePointSelectorWidget', [data.product, data.isDisabled]) %}
            {% endif %}

            <div class="{{ data.config.name }}__form">
                {% widget 'ProductOptionConfiguratorWidget' args [data.product] only %}{% endwidget %}

                {% if not shipmentTypeServicePointSelectorWidget or not shipmentTypeServicePointSelectorWidget.hasShipmentTypeWithRequiredLocation %}
                    {% widget embed.buyBoxWidget only %}{% endwidget %}
                {% endif %}

                {% if can('SeeAddToCartPermissionPlugin') %}
                    {% widget shipmentTypeServicePointSelectorWidget only %}{% endwidget %}

                    <div class="{{ data.config.name }}__add-to-cart">
                        {% widget 'ProductPackagingUnitWidget' args [data.product, embed.isAddToCartDisabled, data.options] only %}
                        {% elsewidget 'ManageProductMeasurementUnitWidget' args [data.product, embed.isAddToCartDisabled, data.options] only %}
                        {% nowidget %}
                            <p class="product-configurator__field-label">{{ 'cart.item_quantity' | trans }}</p>
                            <div class="product-configurator__cta-row">
                                {% include molecule('quantity-counter') with {
                                    data: {
                                        isDisabled: embed.isAddToCartDisabled,
                                    },
                                } only %}

                                <button
                                    type="submit"
                                    class="button button--lg button--expand product-configurator__add-to-cart-button"
                                    {{ embed.isAddToCartDisabled ? 'disabled' : 'data-init-single-click' }}
                                    {{ qa('add-to-cart-button') }}
                                >
                                    {% include atom('icon') with {
                                        modifiers: ['cart-plus'],
                                        data: {
                                            name: 'cart-plus',
                                        },
                                    } only %}
                                    {{ 'page.detail.add-to-cart' | trans }}
                                </button>
                            </div>
                        {% endwidget %}
                    </div>

                    {% widget 'AddToMultiCartWidget' args [data.isDisabled] only %}{% endwidget %}

                    {% widget 'CartAddProductAsSeparateItemWidget' only %}{% endwidget %}
                {% endif %}

                {% if can('SeeAddToCartPermissionPlugin') %}
                    {% widget 'SspItemAssetSelectorWidget' args [data.product, data.isDisabled] only %}{% endwidget %}
                {% endif %}
            </div>
        {% endblock %}
    {% endwidget %}


    {% if (not isAvailable or not data.product.available) and not isProductAbstract %}
        {% widget 'AvailabilityNotificationSubscriptionWidget' args [data.product] only %}{% endwidget %}
    {% endif %}

    {% if can('SeeShoppingListPermissionPlugin') %}
        <div class="{{ config.name }}__save-to-list">
            {% widget 'AddToShoppingListWidget' args [sku, isDisabled, data.product] only %}{% endwidget %}
        </div>
    {% endif %}

    {% widget 'ProductDiscontinuedNoteWidget' args [sku] only %}{% endwidget %}
{% endblock %}
