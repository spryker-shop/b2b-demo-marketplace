{% extends molecule('customer-list', '@SprykerShop:AgentWidget') %}

{% block body %}
    {% for customer in data.customers %}
        {% set customerName = (customer.first_name ~ ' ' ~ customer.last_name) | trim %}
        <li class="{{ config.name }}__container-item {{ config.jsName }}__container-item"
            data-value="{{ customer.email }}"
            data-label="{{ customerName ?: customer.email }}">
            {% include atom('avatar') with {
                class: config.name ~ '__avatar',
                modifiers: ['sm'],
                data: {
                    placeholder: (customer.first_name | first | upper) ~ (customer.last_name | first | upper),
                },
            } only %}
            <span class="{{ config.name }}__info">
                <span class="{{ config.name }}__name">{{ customer.first_name }} {{ customer.last_name }}</span>
                <span class="{{ config.name }}__email">{{ customer.email }}</span>
            </span>
        </li>
    {% endfor %}
{% endblock %}
