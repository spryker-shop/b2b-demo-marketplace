{% extends view('create-budget', 'SprykerFeature:PurchasingControl') %}

{% block breadcrumbs %}
    {% include molecule('breadcrumb') with {
        data: {
            steps: [
                {
                    label: 'company.account.page-title' | trans,
                    url: url('company/overview'),
                }, 
                {
                    label: 'purchasing_control.cost_center.menu_item' | trans,
                    url: url('company/cost-center'),
                },
                {
                    label: data.currentBreadcrumb | trans,
                }
            ]
        }
    } only %}
{% endblock %}

{% block companyContent %}
    {% include molecule('action-bar', 'ShopUi') with {
        modifiers: ['first', 'middle'],
        data: {
            title: data.title,
        }
    } only %}

    {% block form %}
        {{ parent() }}
    {% endblock %}
{% endblock %}
