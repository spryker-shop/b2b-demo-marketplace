{% extends template('page-layout-auth') %}

{% set successMessages = app.session.flashbag.get('flash.messages.success') %}
{% set hasError = _view.form.vars.errors | length > 0
    or _view.form.email.vars.errors | length > 0 %}
{% set isSent = _view.form.vars.submitted and not hasError %}

{% block content %}
    {% include molecule('auth-recovery', 'CustomerPage') with {
        data: {
            step: isSent ? 'sent' : 'request',
            form: _view.form,
            email: _view.form.email.vars.value,
            hasError: hasError,
        },
    } only %}
{% endblock %}
