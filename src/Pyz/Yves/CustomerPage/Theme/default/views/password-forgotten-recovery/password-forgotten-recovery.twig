{% extends template('page-layout-auth') %}

{% set formErrors = _view.form.vars.errors %}
{% set passwordErrors = _view.form.password.vars.errors %}
{% set passErrors = _view.form.password.pass.vars.errors %}
{% set confirmErrors = _view.form.password.confirm.vars.errors %}
{% set hasError = (formErrors | length > 0)
    or (passwordErrors | length > 0)
    or (passErrors | length > 0)
    or (confirmErrors | length > 0) %}

{% block content %}
    {% embed molecule('auth-layout', 'CustomerPage') with {
        data: {
            heading: 'customer.password.restore' | trans,
            subtitle: 'customer.password.restore.subtitle' | trans,
        },
        hasError: hasError,
        formErrors: formErrors,
        passwordErrors: passwordErrors,
        passErrors: passErrors,
        confirmErrors: confirmErrors,
    } only %}
        {% block card %}
            {{ form_start(_view.form, {
                attr: {
                    class: config.name ~ '__form',
                    novalidate: 'novalidate',
                },
            }) }}
                {{ form_widget(_view.form.restore_password_key) }}

                <div class="{{ config.name }}__fields">
                    <div class="{{ config.name }}__field">
                        <label for="{{ _view.form.password.pass.vars.id }}" class="{{ config.name }}__label">
                            {{- 'forms.password' | trans -}}
                        </label>
                        {{ form_widget(_view.form.password.pass, {
                            attr: {
                                class: hasError ? 'input--error' : '',
                            },
                        }) }}
                    </div>

                    <div class="{{ config.name }}__field">
                        <label for="{{ _view.form.password.confirm.vars.id }}" class="{{ config.name }}__label">
                            {{- 'forms.confirm-password' | trans -}}
                        </label>
                        {{ form_widget(_view.form.password.confirm, {
                            attr: {
                                class: hasError ? 'input--error' : '',
                            },
                        }) }}
                    </div>

                    {% if hasError %}
                        {% set errorText %}
                            {%- for error in formErrors %}{{ error.message | trans }} {% endfor -%}
                            {%- for error in passwordErrors %}{{ error.message | trans }} {% endfor -%}
                            {%- for error in passErrors %}{{ error.message | trans }} {% endfor -%}
                            {%- for error in confirmErrors %}{{ error.message | trans }} {% endfor -%}
                        {% endset %}
                        {% include molecule('flash-message') with {
                            modifiers: ['alert', 'notification'],
                            data: {
                                isStatic: true,
                                text: errorText | trim,
                            },
                        } only %}
                    {% endif %}
                </div>

                <button
                    type="submit"
                    class="button {{ config.name }}__submit"
                    data-init-single-click
                    {{ qa('submit-button') }}
                >
                    {{- 'customer.password.restore.submit' | trans -}}
                </button>

                <a href="{{ url('login') }}" class="{{ config.name }}__back" {{ qa('cancel-button') }}>
                    {{- 'customer.forgotten-password.back_to_login' | trans -}}
                </a>

                {{ form_end(_view.form) }}
        {% endblock %}
    {% endembed %}
{% endblock %}
