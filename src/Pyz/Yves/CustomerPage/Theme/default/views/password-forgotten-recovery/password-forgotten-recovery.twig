{% extends template('page-layout-auth') %}

{% set hasError = _view.form.vars.errors | length > 0
    or _view.form.password.vars.errors | length > 0
    or _view.form.password.pass.vars.errors | length > 0
    or _view.form.password.confirm.vars.errors | length > 0 %}

{% block content %}
    {% include molecule('auth-recovery', 'CustomerPage') with {
        data: {
            step: _view.isSuccess | default(false) ? 'success' : 'reset',
            form: _view.form,
            hasError: hasError,
        },
    } only %}
{% endblock %}
