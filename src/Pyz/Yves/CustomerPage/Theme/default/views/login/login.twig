{% extends template('page-layout-auth') %}

{% set authErrors = app.session.flashbag.get('flash.messages.error') %}

{% block content %}
    {% include molecule('auth-login', 'CustomerPage') with {
        data: {
            form: _view.loginForm,
            subtitle: 'customer.login.subtitle',
            showForgotPassword: true,
            hasFlashError: authErrors is not empty,
            mfaUrl: 'multiFactorAuth/getCustomerEnabledTypes',
        },
    } only %}
{% endblock %}
