{% extends template('page-layout-auth') %}

{% set authErrors = app.session.flashbag.get('flash.messages.error') %}
{% set hasError = authErrors is not empty
    or _view.loginForm.vars.errors | length > 0
    or _view.loginForm.email.vars.errors | length > 0
    or _view.loginForm.password.vars.errors | length > 0 %}

{% block content %}
    {% embed molecule('auth-layout', 'CustomerPage') with {
        data: {
            heading: 'customer.login.welcome_back' | trans,
            subtitle: 'customer.login.subtitle' | trans,
        },
        hasError: hasError,
    } only %}
        {% block card %}
            {{ form_start(_view.loginForm, {
                attr: {
                    class: config.name ~ '__form',
                    novalidate: 'novalidate',
                },
            }) }}
                <div class="{{ config.name }}__fields">
                    <div class="{{ config.name }}__field">
                        <label for="{{ _view.loginForm.email.vars.id }}" class="{{ config.name }}__label">
                            {{- 'customer.login.email' | trans -}}
                        </label>
                        {{ form_widget(_view.loginForm.email, {
                            attr: {
                                autocomplete: 'email',
                                class: hasError ? 'input--error ' : '',
                            },
                        }) }}
                    </div>

                    <div class="{{ config.name }}__field">
                        <div class="{{ config.name }}__label-row">
                            <label for="{{ _view.loginForm.password.vars.id }}" class="{{ config.name }}__label">
                                {{- 'customer.login.password' | trans -}}
                            </label>
                            <a
                                href="{{ url('password/forgotten') }}"
                                class="{{ config.name }}__forgot"
                                {{ qa('customer-forgot-password-link') }}
                            >
                                {{- 'forms.forgot-password' | trans -}}
                            </a>
                        </div>
                        {{ form_widget(_view.loginForm.password, {
                            attr: {
                                class: hasError ? 'input--error ' : '',
                            },
                        }) }}
                    </div>

                    {% if hasError %}
                        {% include molecule('flash-message') with {
                            modifiers: ['alert', 'notification'],
                            data: {
                                isStatic: true,
                                text: 'customer.login.error' | trans,
                            },
                        } only %}
                    {% endif %}
                </div>

                <button
                    type="submit"
                    class="button {{ config.name }}__submit"
                    data-init-single-click
                    {{ qa('submit-button') }}
                >
                    {{- 'customer.login.submit' | trans -}}
                </button>

                <a
                    href="{{ url('home') }}"
                    class="link link--subtle link--no-decoration link--sm {{ config.name }}__guest"
                    {{ qa('continue-as-guest-link') }}
                >
                    {{- 'customer.login.continue_as_guest' | trans -}}
                    {% include atom('font-icon') with {
                        class: config.name ~ '__guest-icon',
                        data: { name: 'arrow_forward' },
                    } only %}
                </a>

                {% if _view.loginForm.remember_me is defined %}
                    <div class="{{ config.name }}__hidden" hidden>
                        {{ form_row(_view.loginForm.remember_me) }}
                    </div>
                {% endif %}

                {{ form_end(_view.loginForm) }}
        {% endblock %}
    {% endembed %}

    {% widget 'MultiFactorAuthHandlerWidget' with {
        data: {
            id: _view.loginForm.vars.name,
            url: 'multiFactorAuth/getCustomerEnabledTypes',
            formSelector: '[name="' ~ _view.loginForm.vars.name ~ '"]',
            isLoginFlow: 'true',
            isJsEnabledHandler: 'true',
        }
    } only %}
    {% endwidget %}
{% endblock %}
