{% extends template('page-layout-customer', 'CustomerPage') %}

{% define data = {
    form: _view.form,
    activePage: 'newsletter',
    title: 'customer.account.newsletter' | trans
} %}

{% block breadcrumbs %}
    {% include molecule('breadcrumb') with {
        data: {
            steps: [{
                label: 'customer.account' | trans,
                url: url('customer/overview'),
            }, {
                label: 'customer.account.newsletter' | trans,
            }],
        },
    } only %}
{% endblock %}

{% block customerContent %}
    {% include molecule('action-bar') with {
        modifiers: ['first', 'middle'],
        data: {
            title: 'customer.newsletter.subscription' | trans,
        }
    } only %}

    <p class="text-small">{{ 'customer.newsletter.text' | trans }}</p>

    {% include molecule('form') with {
        data: {
            form: data.form,
            submit: {
                enable: true
            }
        }
    } only %}
{% endblock %}
