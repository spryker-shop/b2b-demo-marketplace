{% extends template('widget') %}

{% define data = {
    navigation: navigation,
} %}

{% block body %}
    {% set title = '' %}

    {% if data.navigation.nodes | length > 0 %}
        {% set firstNode = data.navigation.nodes | first %}
        {% set nodeType = firstNode.nodeType %}

        {% if nodeType == 'category' %}
            {% set title = 'global.top_categories' | trans %}
        {% endif %}

        {% if nodeType == 'link' %}
            {% set title = 'global.popular_brands' | trans %}
        {% endif %}

        {% if nodeType == 'cms_page' %}
            {% set title = 'global.about' | trans %}
        {% endif %}
    {% endif %}

    {% include molecule('navigation-item', 'ContentNavigationWidget') with {
        class: 'col col--sm-12 col--md-4 ',
        data: {
            nodes: data.navigation.nodes,
            title: title,
        },
    } only %}
{% endblock %}
