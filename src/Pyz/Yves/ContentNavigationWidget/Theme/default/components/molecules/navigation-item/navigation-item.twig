{% extends model('component') %}
{% import _self as component %}

{% define config = {
    name: 'navigation-item',
} %}

{% define data = {
    nodes: required,
    title: '',
    toggleClass: '',
    template: 'navigation-list',
    templateModifiers: ['secondary', 'footer'],
} %}

{% block body %}
    {% if data.title %}
        <strong class="{{ component.renderClass('title', modifiers) }} title--footer">
            {{ data.title }}
        </strong>
    {% endif %}

    {% block navigationTemplate %}
        {% include molecule(data.template) with {
            modifiers: data.templateModifiers,
            data: {
                nodes: data.nodes,
            },
        } only %}
    {% endblock %}
{% endblock %}
